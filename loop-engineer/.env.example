# —— Worker 供应商密钥（便宜、够用的基础编码/测试/文档模型）——
# 指挥大师(orchestrator/planner)默认用你本机 `claude login` 的订阅，无需 key。
# worker/reviewer 用下面的第三方 Anthropic 兼容端点。

# GLM-5.2（Z.ai）—— 默认 coder
GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/anthropic
GLM_MODEL=glm-5.2

# Kimi（Moonshot）—— 默认内层 reviewer（跨模型审）
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/anthropic
KIMI_MODEL=kimi-k2.5

# DeepSeek —— agentic 场景用（Anthropic 兼容端点，可当 coder；直连）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-pro

# HiLinkup —— OpenAI 兼容多模型网关（一 key 调 GLM/Kimi/DeepSeek/Qwen…）
# 仅用于单发 chat 角色（reviewer/planner/回流），供应商写 "hilinkup:<model>"，如：
#   reviewer=hilinkup:kimi-k2.7-code  outerReviewer=hilinkup:deepseek-v4-pro
# 注意：HiLinkup 只有中国模型、无 Anthropic 端点，故不能驱动 agentic coder(claude -p)。
# 可用模型示例：glm-5.1 / glm-5 / kimi-k2.7-code / deepseek-v4-pro / qwen3.7-max（无 glm-5.2）
HILINKUP_API_KEY=
HILINKUP_BASE_URL=https://hilinkup.com/v1

# —— HTTP 编排 API（W1）——
# WORKBENCH_TOKEN=            # 鉴权:所有端点校验 x-workbench-token(fail-closed,未设一律拒)
# LOOP_HTTP_PORT=4050         # 默认 4050
# LOOP_HTTP_HOST=127.0.0.1    # 默认只绑本机;远程可达经隧道(B4)
# LOOP_REPO_ROOT=             # 设了则 /plan 的 repo 必须落在其下(白名单根前缀)

# —— 回调 webhook（W5 · 契约 v2 C2）——
# hack5 的接收端 URL;未设 = 跳过回调(仅本地记录 lifecycle)
# WORKBENCH_CALLBACK_URL=
# 回调 HMAC 签名共享密钥;设了则带 x-workbench-signature: sha256=<hex> 头,hack5 同法验签防伪造
# WORKBENCH_CALLBACK_SECRET=

# —— 沙箱（W2 · B2）——
# 逗号分隔,给 coder/reviewer 沙箱额外放行的 env 键(默认白名单只含 PATH/HOME/locale 等)
# LOOP_SANDBOX_PASSTHROUGH=

# —— 行为 / 临时覆盖（不改 loop-engineer.config.json）——
# 无 key 时用 mock 供应商本地跑通编排：LOOP_CODER=mock LOOP_REVIEWER=mock LOOP_PLANNER=mock
# 启用外层 reviewer：在 config.json 的 providers.outerReviewer 填 "deepseek"，或 LOOP_OUTER_REVIEWER=deepseek
# 也可 LOOP_WATCH_DIRS=<dir> 临时指定监听目录

# —— 并发（W7）——
# HTTP 编排池的最大并发 job 数（默认 1 = 串行,契约 v2 B1）。同一 repo 的 job 始终串行,
# 只有不同 repo 才并行。一场 Mini 想同时跑几十个想法时调高,如 LOOP_CONCURRENCY=8。
# LOOP_CONCURRENCY=1

# —— job 超时（契约 v2 · Q2）——
# 单个 job 超时上限（毫秒,默认 30 分钟）。超时 → kill 编码/评审子进程 + 清 worktree + 标 failed。
# LOOP_JOB_TIMEOUT_MS=1800000
