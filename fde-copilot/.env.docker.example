# Optional model override. Leave empty to use the subscription default.
# CLAUDE_MODEL=

# Model routing. The UI can override this per project.
FDE_DEFAULT_PROVIDER=claude
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_MODEL=qwen2.5-7b-instruct-mlx
# LMSTUDIO_API_KEY=  # only when LM Studio authentication is enabled

# Maximum turns the agent may take for one customer message.
AGENT_MAX_TURNS=40

# Keep false unless this container has a configured Git remote and credentials.
AUTO_COMMIT=false
AUTO_PUSH=false

# Do not set this unless a reverse proxy injects x-workbench-token for every API request.
# WORKBENCH_TOKEN=
