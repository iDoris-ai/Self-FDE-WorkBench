# —— 执行模式 / Agent SDK 认证（CC-58：默认云化，无本机订阅依赖）——
# EXECUTION_MODE=api（默认）：full agent-sdk 路径走云端 Anthropic 兼容端点，绝不静默回落本机订阅。
#   优先用已配好的 ANTHROPIC_*；否则复用 loop-engineer 的 DeepSeek 云端点
#   （DEEPSEEK_API_KEY + DEEPSEEK_BASE_URL，非 Anthropic 官方 key）。两者都没有 → 启动即 fail-closed 报错。
#   注：默认「快 chat」直连走 HiLinkup（配了 HILINKUP_API_KEY 时），本就零订阅依赖。
# EXECUTION_MODE=local：显式 opt-in，才允许 SDK 复用本机 `claude login` 订阅（自建/离线开发）。
# EXECUTION_MODE=api

# agentic full 路径的云端点（推荐：复用 loop-engineer 同一套 DeepSeek 云 key）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
# DEEPSEEK_MODEL=deepseek-v4-pro
# 快 chat 直连（默认路径）：一 key 多模型的 HiLinkup 网关
# HILINKUP_API_KEY=
# （可选）官方 Anthropic key —— 非默认，显式给了才用
# ANTHROPIC_API_KEY=

# 模型（留空 = 跟随端点默认）
# CLAUDE_MODEL=

# 每轮 agent 的最大内部 turn 数（防止失控）
AGENT_MAX_TURNS=40

# 生成 spec 后是否自动 git commit 客户目录（默认 false，UI 里有手动按钮）
AUTO_COMMIT=false

# 自动 commit 时是否 push（需已配置好 remote 与凭证）
AUTO_PUSH=false

# 鉴权（admin / 编排层）：设置后 clients/projects/commit/usage 需带 x-workbench-token 匹配头。
# 不设 = 仅本机使用（dev/start 默认 bind 127.0.0.1）。面向公网/无人值守务必设置。
# WORKBENCH_TOKEN=

# W3 / 契约 v2 · B3：参赛者会话（chat + 读自己项目）用「作用域 token」。
# 由 hack5 用此共享密钥 HMAC 签发，WorkBench 只验签 + 比对路径子树（越权 → 403）。
# 令牌格式：base64url(payloadJson) + "." + base64url(HMAC_SHA256(payloadBytes, 密钥))
#   payloadJson = {"client":"<clientSlug>","project":"<projectSlug>","exp"?:<unix秒>}
# admin token 仍全通（server-to-server）。不设本密钥且不设 admin → 仅本机放行。
# WORKBENCH_SCOPED_SECRET=

# W2：把 spec push 到「参赛者命名的公有仓库」用的 push token（也可由 /api/commit 请求体 pushToken 注入）。
# 约束（契约 v2 · B2）：用仓库级、短时效 fine-grained token（scope 仅限该一个 repo），
# 落在隔离 bot 账户下，绝不用 account 级 PAT。此 token 只在 fde-copilot 的 git-push 边界使用，
# 不会进入 loop-engineer 的代码执行沙箱。
# WORKBENCH_PUSH_TOKEN=
# 目标仓库 push 的目标分支（默认 main）
# WORKBENCH_PUSH_BRANCH=main
# 允许注入 push token 的 host 白名单（逗号分隔，默认 github.com）。
# 非白名单 host 的 repo 会被 /api/commit 以 400 拒绝，防 push 凭证外泄到任意主机。
# WORKBENCH_ALLOWED_PUSH_HOSTS=github.com
