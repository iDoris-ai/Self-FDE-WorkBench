# Claude Agent SDK 认证
# 方式一（推荐，零 key）：本机已 `claude login` 登录 Claude Code，SDK 复用其订阅认证，无需填任何 key。
# 方式二：使用 Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...

# 模型（留空 = 跟随 Claude Code 默认）
# CLAUDE_MODEL=claude-sonnet-5

# 每轮 agent 的最大内部 turn 数（防止失控）
AGENT_MAX_TURNS=40

# 生成 spec 后是否自动 git commit 客户目录（默认 false，UI 里有手动按钮）
AUTO_COMMIT=false

# 自动 commit 时是否 push（需已配置好 remote 与凭证）
AUTO_PUSH=false

# 鉴权：设置后所有 API 需带 x-workbench-token 匹配头（面向公网/无人值守务必设置）。
# 不设 = 仅本机使用（dev/start 默认 bind 127.0.0.1）。
# WORKBENCH_TOKEN=
